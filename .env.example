# ── Application ──────────────────────────────────────────────
APP_NAME=web-scraper-service
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
LOG_JSON=false

# ── API Server ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_KEY=sk-dev-change-me-in-production

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_STORAGE_URI=redis://localhost:6379/3

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=scraper
POSTGRES_PASSWORD=scraper_secret
POSTGRES_DB=scraper_db
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# Redis DB assignments:
#   DB 0: URL dedup (dedup:{spider_name})
#   DB 1: Job state cache (job:{job_id}, TTL 24h)
#   DB 2: Crawl queues (queue:{spider_name}, ZSet)
#   DB 3: API rate limiting

# ── Celery ──────────────────────────────────────────────────
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/2
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_CONCURRENCY=4
FLOWER_PORT=5555

# ── Proxy ───────────────────────────────────────────────────
PROXY_ENABLED=false
# 代理池 API URL（批量获取，缓存到本地文件，耗尽后刷新）
PROXY_POOL_URL=
PROXY_POOL_AUTH_KEY=
PROXY_POOL_AUTH_PWD=
PROXY_ROTATION_STRATEGY=round-robin
# Comma-separated proxy list (HTTP/SOCKS5)
PROXY_LIST=
# 代理缓存文件路径（默认 BASE_DIR/proxy_cache.json）
PROXY_CACHE_FILE=

# ── Captcha ─────────────────────────────────────────────────
CAPTCHA_ENABLED=false
CAPTCHA_SERVICE=2captcha
TWOCAPTCHA_API_KEY=
ANTICAPTCHA_API_KEY=

# ── S3 Object Storage ──────────────────────────────────────
S3_ENABLED=false
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=scraper-assets
S3_REGION=us-east-1

# ── Elasticsearch ───────────────────────────────────────────
ES_ENABLED=false
ES_HOSTS=http://localhost:9200

# ── MongoDB ─────────────────────────────────────────────────
MONGO_ENABLED=false
MONGO_URI=mongodb://localhost:27017
MONGO_DB=scraper_db

# ── Snapshot Database (独立库) ─────────────────────────────
# 默认从 PostgreSQL 凭据派生，仅库名固定为 zbd_crawler_data
# 显式设置可覆盖：postgresql+asyncpg://user:pass@host:port/zbd_crawler_data
SNAPSHOT_DATABASE_URL=

# ── Bailian (Qwen LLM 抽取) ───────────────────────────────
# OpenAI 兼容 API，用于 djg_data 字段抽取
DASHSCOPE_API_KEY=
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.5-35b-a3b

# ── nfra 定时调度 ─────────────────────────────────────────
# 每日定时采集（Asia/Shanghai 时区）；关闭设为 false
NFRA_SCHEDULE_ENABLED=true
NFRA_SCHEDULE_CRON=0 8 * * *
NFRA_SCHEDULE_PAGES=5
NFRA_CAPITAL_SCHEDULE_ENABLED=true
NFRA_EQUITY_SCHEDULE_ENABLED=true

# ── Scrapling / Fetcher ────────────────────────────────────
SCRAPLING_ADAPTIVE=true
PLAYWRIGHT_HEADLESS=true
CAMOUFOX_HEADLESS=true
DEFAULT_TIMEOUT=30
DEFAULT_RETRY_TIMES=3
DEFAULT_RETRY_DELAY=1.0
DEFAULT_CONCURRENCY=5
DEFAULT_DOWNLOAD_DELAY=0.5
